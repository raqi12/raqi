PORT=3000
MONGODB_URI=mongodb://localhost:27017/raqi
JWT_SECRET=raqi-local-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
NODE_ENV=development

# Firebase Admin (FCM push) — fill from Firebase Console → Project settings → Service accounts
FIREBASE_PROJECT_ID=alraaqi-ly
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-fbsvc@alraaqi-ly.iam.gserviceaccount.com
# Paste private key with literal \n newlines, wrapped in double quotes
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Web client config (for apps / admin FCM registration — not used by Nest Admin SDK)
FIREBASE_WEB_API_KEY=AIzaSyAlzqZV3jh1pB1Ni9LkUrLKmxnJL-J2hDg
FIREBASE_WEB_AUTH_DOMAIN=alraaqi-ly.firebaseapp.com
FIREBASE_WEB_STORAGE_BUCKET=alraaqi-ly.firebasestorage.app
FIREBASE_WEB_MESSAGING_SENDER_ID=607853680583
FIREBASE_WEB_APP_ID=1:607853680583:web:3cff99a474ab0db189abe2
FIREBASE_WEB_MEASUREMENT_ID=G-Y2M5BX1QFS
FIREBASE_VAPID_KEY=

# iSend SMS (OTP) — optional when OTP_FIXED_CODE is set
ISEND_API_TOKEN=
ISEND_SENDER_ID=iSend
ISEND_API_URL=https://isend.com.ly/api/v3/sms/send
# false = do not call iSend (recommended while OTP_FIXED_CODE is in use)
SMS_OTP_ENABLED=false
# Fixed OTP for all flows (register, reset password, delete). Use 1111 in testing.
OTP_FIXED_CODE=1111
OTP_DEV_MODE=false
