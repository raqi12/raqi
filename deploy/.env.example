# Copy to /var/www/raqi/.env on the VPS before first deploy.
# cp deploy/.env.example /var/www/raqi/.env

NODE_ENV=production
PORT=3000

# Docker Compose service name for MongoDB
MONGODB_URI=mongodb://mongo:27017/raqi

# Generate: openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

CORS_ORIGINS=https://dashboard.raqii.com.ly,http://localhost:5173
