# Copy to /var/www/raqi/.env on the VPS before first deploy.
# cp deploy/.env.example /var/www/raqi/.env

NODE_ENV=production
PORT=3000

# MongoDB (Docker Compose mongo service on localhost)
MONGODB_URI=mongodb://127.0.0.1:27017/raqi

# Generate: openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

CORS_ORIGINS=https://dashboard.raqii.com.ly,http://localhost:5173

# Firebase Admin (FCM) — required for push; copy from service account JSON
FIREBASE_PROJECT_ID=alraaqi-ly
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-fbsvc@alraaqi-ly.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# iSend SMS (OTP) — optional when OTP_FIXED_CODE is set
ISEND_API_TOKEN=
ISEND_SENDER_ID=iSend
ISEND_API_URL=https://isend.com.ly/api/v3/sms/send
SMS_OTP_ENABLED=false
OTP_FIXED_CODE=1111
OTP_DEV_MODE=false
