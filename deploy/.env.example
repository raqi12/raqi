# Copy to /var/www/raqi/.env on the VPS before first deploy.
# cp deploy/.env.example /var/www/raqi/.env

NODE_ENV=production
PORT=3000

# MongoDB (Docker Compose mongo service on localhost)
MONGODB_URI=mongodb://127.0.0.1:27017/raqi

# Generate: openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

CORS_ORIGINS=https://dashboard.raqii.com.ly,http://localhost:5173

# Return OTP in register/forgot-password responses for testing (disable in production)
OTP_DEBUG=true
OTP_DEV_CODE=123456
